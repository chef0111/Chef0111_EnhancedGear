          "type": "minecraft:select",
          "property": "minecraft:using",
          "cases": [
            { "when": "true", "model": "minecraft:item/shield/xuanwu_shield_blocking" }
          ],
          "fallback": "minecraft:item/shield/xuanwu_shield"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:select",
      "property": "minecraft:using",
      "cases": [
        { "when": "true", "model": "minecraft:item/shield_blocking" }
      ],
      "fallback": "minecraft:item/shield"
    }
  }
}
