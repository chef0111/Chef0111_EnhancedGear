{
	"oversized_in_gui": true,
	"model": {
		"type": "condition",
		"property": "using_item",
		"on_false": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": "The Soul Hunter",
					"model": {
						"type": "select",
						"property": "charge_type",
						"cases": [
							{ "when": "arrow", "model": { "type": "model", "model": "item/crossbow/soul_hunter_arrow" } },
							{ "when": "rocket", "model": { "type": "model", "model": "item/crossbow/soul_hunter_firework" } }
						],
						"fallback": {
							"type": "model",
							"model": "item/crossbow/soul_hunter"
						}
					}
				}
			],
			"fallback": {
				"type": "select",
				"property": "charge_type",
				"cases": [
					{ "when": "arrow", "model": { "type": "model", "model": "item/crossbow_arrow" } },
					{ "when": "rocket", "model": { "type": "model", "model": "item/crossbow_firework" } }
				],
				"fallback": {
					"type": "model",
					"model": "item/crossbow"
				}
			}
		},
		"on_true": {
			"type": "range_dispatch",
			"property": "use_duration",
			"scale": 0.05,
			"entries": [
				{
					"threshold": 0.58,
					"model": {
						"type": "select",
						"property": "component",
						"component": "custom_name",
						"cases": [
							{
								"when": "The Soul Hunter",
								"model": {
									"type": "model",
									"model": "item/crossbow/soul_hunter_pulling_1"
								}
							}
						],
						"fallback": {
							"type": "model",
							"model": "item/crossbow_pulling_1"
						}
					}
				},
				{
					"threshold": 1.0,
					"model": {
						"type": "select",
						"property": "component",
						"component": "custom_name",
						"cases": [
							{
								"when": "The Soul Hunter",
								"model": {
									"type": "model",
									"model": "item/crossbow/soul_hunter_pulling_2"
								}
							}
						],
						"fallback": {
							"type": "model",
							"model": "item/crossbow_pulling_2"
						}
					}
				}
			],
			"fallback": {
				"type": "select",
				"property": "component",
				"component": "custom_name",
				"cases": [
					{
						"when": "The Soul Hunter",
						"model": {
							"type": "model",
							"model": "item/crossbow/soul_hunter_pulling_0"
						}
					}
				],
				"fallback": {
					"type": "model",
					"model": "item/crossbow_pulling_0"
				}
			}
		}
	}
}
