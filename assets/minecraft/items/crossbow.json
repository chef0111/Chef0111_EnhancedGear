{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_name",
    "cases": [
      {
        "when": "The Soul Hunter",
        "model": {
          "type": "minecraft:select",
          "property": "minecraft:pulling",
          "cases": [
            {
              "when": "true",
              "model": {
                "type": "minecraft:select",
                "property": "minecraft:pull",
                "cases": [
                  { "when": 0.58, "model": "minecraft:item/crossbow/soul_hunter_pulling_1" },
                  { "when": 1.0, "model": "minecraft:item/crossbow/soul_hunter_pulling_2" }
                ],
                "fallback": "minecraft:item/crossbow/soul_hunter_pulling_0"
              }
            }
          ],
          "fallback": {
            "type": "minecraft:select",
            "property": "minecraft:charged",
            "cases": [
              { "when": "arrow", "model": "minecraft:item/crossbow/soul_hunter_arrow" },
              { "when": "firework", "model": "minecraft:item/crossbow/soul_hunter_firework" }
            ],
            "fallback": "minecraft:item/crossbow/soul_hunter"
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:select",
      "property": "minecraft:pulling",
      "cases": [
        {
          "when": "true",
          "model": {
            "type": "minecraft:select",
            "property": "minecraft:pull",
            "cases": [
              { "when": 0.58, "model": "minecraft:item/crossbow_pulling_1" },
              { "when": 1.0, "model": "minecraft:item/crossbow_pulling_2" }
            ],
            "fallback": "minecraft:item/crossbow_pulling_0"
          }
        }
      ],
      "fallback": {
        "type": "minecraft:select",
        "property": "minecraft:charged",
        "cases": [
          { "when": "arrow", "model": "minecraft:item/crossbow_arrow" },
          { "when": "firework", "model": "minecraft:item/crossbow_firework" }
        ],
        "fallback": "minecraft:item/crossbow"
      }
    }
  }
}
